TUYA_ACCESS_ID=your_access_id_here
TUYA_ACCESS_SECRET=your_access_secret_here
TUYA_DEVICE_ID=your_device_id_here

# Opcionales
# ACCESS_PIN=1234                      # PIN de acceso (muy recomendado en produccion)
# SYNC_TOKEN=cadena_larga_aleatoria    # permite al cron externo llamar /api/sync?token=... sin PIN
# TUYA_TRIAL_END=2026-12-31            # vencimiento del trial IoT Core (aviso anticipado)
# TELEGRAM_BOT_TOKEN=123:abc           # alertas por Telegram (@BotFather)
# TELEGRAM_CHAT_ID=123456789
# DATABASE_URL=postgres://...          # persistencia (sin ella: modo stateless)
